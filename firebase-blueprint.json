{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile and personalization data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "preferredLanguage": { "type": "string", "enum": ["en", "sw"] },
        "context": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Metadata for a conversation session",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "agentType": { "type": "string", "enum": ["General", "Coding", "Teaching", "Motivation", "Business", "Research", "Engineering"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "Individual messages in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "multimodal": { "type": "boolean" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "chats": {
      "schema": "Chat",
      "description": "Collection of chat sessions"
    },
    "messages": {
      "schema": "Message",
      "description": "Collection of messages for all chats"
    }
  }
}
